---
/**
 * api/v1.astro — the catch-all client interceptor routing engine.
 *
 * This static page IS the mock API. On load it reads window.location.hash,
 * base64url-decodes and inflates the payload envelope, honors the simulated
 * latency, then replaces the DOM with the response: status line, headers,
 * and a syntax-highlighted body. Zero server involvement — the fragment is
 * never transmitted anywhere.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="MockDock Interceptor — /api/v1"
  description="MockDock client-side mock API interceptor. Decodes the payload in your URL hash and renders it as an API response."
  canonicalPath="/api/v1"
  noindex={true}
>
  <div id="app" class="mx-auto min-h-screen max-w-4xl px-4 py-8">
    <!-- Initial paint: replaced entirely by the interceptor script -->
    <div id="boot" class="text-xs text-dock-300">
      <p><span class="text-mint">mockdock</span><span class="text-dock-400">@v1</span> ~ $ intercepting request<span class="dock-cursor"></span></p>
    </div>
  </div>
</BaseLayout>

<script>
  import { tokenFromHash, envelopeFromToken, statusText } from '../../lib/hashCodec.js';

  const app = document.getElementById('app');

  const esc = (s) =>
    String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c]);

  /** Lightweight JSON syntax highlighter (input must be pre-escaped-safe text). */
  function highlightJSON(text) {
    return esc(text).replace(
      /(&quot;(?:\\.|(?!&quot;)[^\\])*&quot;)(\s*:)?|\b(true|false|null)\b|-?\b\d+(?:\.\d+)?(?:[eE][+-]?\d+)?\b/g,
      (match, str, colon, kw) => {
        if (str) return colon ? `<span class="tok-key">${str}</span>${colon}` : `<span class="tok-str">${str}</span>`;
        if (kw) return `<span class="tok-kw">${kw}</span>`;
        return `<span class="tok-num">${match}</span>`;
      }
    );
  }

  function statusColor(code) {
    if (code >= 500) return 'text-alert';
    if (code >= 400) return 'text-flare';
    if (code >= 300) return 'text-violet-glow';
    return 'text-mint';
  }

  function renderSkeleton(delay) {
    app.innerHTML = `
      <div class="text-xs text-dock-300">
        <p>$ awaiting response <span class="text-flare">— simulated latency: ${Number(delay)}ms</span></p>
        <div class="mt-4 space-y-2" role="status" aria-label="Loading">
          <div class="h-4 w-1/3 animate-pulse rounded bg-dock-700"></div>
          <div class="h-3 w-2/3 animate-pulse rounded bg-dock-800"></div>
          <div class="h-3 w-1/2 animate-pulse rounded bg-dock-800"></div>
          <div class="mt-4 h-40 animate-pulse rounded-lg bg-dock-850"></div>
        </div>
      </div>`;
  }

  function renderResponse(env) {
    const code = env.status;
    let bodyHtml;
    let parsedOk = true;
    let pretty = env.body;
    try {
      pretty = JSON.stringify(JSON.parse(env.body), null, 2);
    } catch {
      parsedOk = false;
    }
    bodyHtml = parsedOk ? highlightJSON(pretty) : esc(env.body);

    const headerRows = Object.entries(env.headers)
      .map(
        ([k, v]) =>
          `<div class="flex gap-2"><span class="shrink-0 text-neon">${esc(k)}:</span><span class="break-all text-dock-200">${esc(v)}</span></div>`
      )
      .join('');

    document.title = `${code} ${statusText(code)} — MockDock /api/v1`;

    app.innerHTML = `
      <div class="text-xs">
        <p class="text-dock-400">$ mockdock intercepted <span class="text-dock-300">GET /api/v1</span> — decoded from URL fragment, served by your browser</p>

        <p class="mt-4 text-sm font-bold">
          <span class="text-dock-400">HTTP/1.1</span>
          <span class="${statusColor(code)}">${code} ${esc(statusText(code))}</span>
        </p>

        <section class="mt-3 rounded-lg border border-dock-700 bg-dock-900 p-3 leading-relaxed" aria-label="Response headers">
          ${headerRows || '<span class="text-dock-400">— no headers in envelope —</span>'}
        </section>

        ${
          parsedOk
            ? ''
            : `<p class="mt-3 rounded border border-flare/40 bg-flare/10 px-3 py-2 text-flare">⚠ body is not valid JSON — rendered raw (intentional for malformed-payload testing)</p>`
        }

        <section class="mt-3 overflow-x-auto rounded-lg border border-dock-700 bg-dock-950 p-4" aria-label="Response body">
          <pre class="dock-scroll leading-relaxed text-dock-200">${bodyHtml}</pre>
        </section>

        <p class="mt-4 text-dock-400">
          — end of mock —
          <a class="text-neon hover:underline" href="/">build your own at mockdock.dev</a>
        </p>
      </div>`;
  }

  function renderError(message) {
    app.innerHTML = `
      <div class="text-xs">
        <p class="text-alert">✗ interceptor error: ${esc(message)}</p>
        <p class="mt-2 text-dock-300">The URL fragment could not be decoded. It may be truncated or built by an incompatible version.</p>
        <p class="mt-4"><a class="text-neon hover:underline" href="/">← generate a fresh mock URL</a></p>
      </div>`;
  }

  function renderIdle() {
    app.innerHTML = `
      <div class="text-xs">
        <p class="text-dock-300"><span class="text-mint">mockdock</span><span class="text-dock-400">@v1</span> ~ $ no payload detected</p>
        <p class="mt-3 leading-relaxed text-dock-300">
          This endpoint serves mock responses encoded in the URL hash:
        </p>
        <pre class="mt-3 overflow-x-auto rounded-lg border border-dock-700 bg-dock-950 p-3 text-dock-300">/api/v1<span class="text-neon">#data=&lt;base64url-deflated-envelope&gt;</span></pre>
        <p class="mt-3 leading-relaxed text-dock-300">
          Build one with any of the <a class="text-neon hover:underline" href="/">12 free tools</a> — no signup required.
        </p>
      </div>`;
  }

  async function intercept() {
    const token = tokenFromHash(window.location.hash);
    if (!token) {
      renderIdle();
      return;
    }
    try {
      const env = await envelopeFromToken(token);
      if (env.delay > 0) {
        renderSkeleton(env.delay);
        await new Promise((resolve) => setTimeout(resolve, env.delay));
      }
      renderResponse(env);
    } catch (err) {
      renderError(err && err.message ? err.message : 'unknown decode failure');
    }
  }

  // Run on load and again whenever the hash changes (live re-mocking).
  intercept();
  window.addEventListener('hashchange', intercept);
</script>
