---
/**
 * ConsoleShell.astro — dark terminal console chrome.
 * Sticky left-rail navigation listing all 12 tools (driven by the pSEO
 * dictionary), a titlebar with traffic-light dots, and a <slot /> main pane.
 * Pass `activeSlug` to highlight the current tool.
 */
import { TOOLS, SITE } from '../data/toolsDictionary.js';

const { activeSlug = '' } = Astro.props;
---

<div class="flex min-h-screen flex-col">
  <!-- Titlebar -->
  <header class="sticky top-0 z-40 border-b border-dock-700 bg-dock-900/95 backdrop-blur">
    <div class="flex items-center gap-3 px-4 py-2.5">
      <span class="flex gap-1.5" aria-hidden="true">
        <span class="h-3 w-3 rounded-full bg-alert/80"></span>
        <span class="h-3 w-3 rounded-full bg-flare/80"></span>
        <span class="h-3 w-3 rounded-full bg-mint/80"></span>
      </span>
      <a href="/" class="text-sm font-bold tracking-tight text-dock-200 hover:text-neon">
        <span class="text-neon">mock</span>dock<span class="text-dock-400">.dev</span>
        <span class="ml-2 hidden text-dock-400 sm:inline">~ $</span>
      </a>
      <span class="ml-auto hidden items-center gap-2 text-[11px] text-dock-400 md:flex">
        <span class="rounded border border-dock-700 bg-dock-850 px-1.5 py-0.5 text-mint">100% free</span>
        <span class="rounded border border-dock-700 bg-dock-850 px-1.5 py-0.5">no signup</span>
        <span class="rounded border border-dock-700 bg-dock-850 px-1.5 py-0.5">no server</span>
      </span>
    </div>

    <!-- Mobile tool strip (rail is hidden below lg) -->
    <nav class="dock-scroll flex gap-1 overflow-x-auto border-t border-dock-700 px-2 py-1.5 lg:hidden" aria-label="Tools">
      {
        TOOLS.map((tool, i) => (
          <a
            href={`/mock/${tool.slug}`}
            class:list={[
              'whitespace-nowrap rounded px-2 py-1 text-[11px]',
              tool.slug === activeSlug
                ? 'bg-neon/10 text-neon'
                : 'text-dock-300 hover:bg-dock-800 hover:text-dock-200',
            ]}
            aria-current={tool.slug === activeSlug ? 'page' : undefined}
          >
            {String(i + 1).padStart(2, '0')}·{tool.navLabel}
          </a>
        ))
      }
    </nav>
  </header>

  <div class="flex flex-1 items-stretch">
    <!-- Sticky left rail -->
    <aside class="hidden w-64 shrink-0 border-r border-dock-700 bg-dock-900 lg:block">
      <nav class="dock-scroll sticky top-[49px] max-h-[calc(100vh-49px)] overflow-y-auto p-3" aria-label="Tools">
        <p class="mb-2 px-2 text-[10px] uppercase tracking-[0.2em] text-dock-400">./tools — 12 loaded</p>
        <ul class="space-y-0.5">
          {
            TOOLS.map((tool, i) => {
              const active = tool.slug === activeSlug;
              return (
                <li>
                  <a
                    href={`/mock/${tool.slug}`}
                    class:list={[
                      'group flex items-baseline gap-2 rounded px-2 py-1.5 text-xs transition-colors',
                      active
                        ? 'border-l-2 border-neon bg-neon/10 text-neon'
                        : 'border-l-2 border-transparent text-dock-300 hover:bg-dock-800 hover:text-dock-200',
                    ]}
                    aria-current={active ? 'page' : undefined}
                  >
                    <span class:list={['tabular-nums', active ? 'text-neon' : 'text-dock-400']}>
                      {String(i + 1).padStart(2, '0')}
                    </span>
                    <span class="truncate">{tool.navLabel}</span>
                    {active && <span class="ml-auto text-neon" aria-hidden="true">●</span>}
                  </a>
                </li>
              );
            })
          }
        </ul>

        <div class="mt-4 border-t border-dock-700 pt-3 text-[10px] leading-relaxed text-dock-400">
          <p class="text-dock-300">$ how it works</p>
          <p class="mt-1">payload → deflate → base64url → <span class="text-neon">#hash</span>. Decoded in your browser. Nothing stored, nothing sent.</p>
        </div>
      </nav>
    </aside>

    <!-- Main pane -->
    <main class="min-w-0 flex-1">
      <slot />
    </main>
  </div>

  <footer class="border-t border-dock-700 bg-dock-900 px-4 py-4 text-[11px] text-dock-400">
    <div class="mx-auto flex max-w-6xl flex-wrap items-center gap-x-4 gap-y-1">
      <span><span class="text-neon">mock</span>dock.dev</span>
      <span>© 2026 — {SITE.tagline}</span>
      <a href="/" class="ml-auto hover:text-neon">all tools</a>
      <a href="/api/v1" class="hover:text-neon">interceptor</a>
    </div>
  </footer>
</div>
